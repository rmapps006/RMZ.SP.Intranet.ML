{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx/client-side-web-part-manifest.schema.json",
  "id": "3e7c4714-a45d-44a0-ac9c-2ab7a8320363",
  "alias": "EmbeddedPortalWebPart",
  "componentType": "WebPart",
  "version": "*",
  "manifestVersion": 2,
  "requiresCustomScript": false,
  "supportedHosts": ["SharePointWebPart"],
  "supportsThemeVariants": true,
  "supportsFullBleed": true,
  "preconfiguredEntries": [
    {
      "groupId": "intranet-suite",
      "group": { "default": "Intranet" },
      "title": { "default": "Embedded Portal" },
      "description": { "default": "Embeds an external portal in a framed mock-browser card." },
      "officeFabricIconFontName": "Globe",
      "properties": {
        "portalUrl": "https://www.example.com",
        "frameHeight": "520",
        "sectionTitle": "Embedded Portal",
        "linkText": "Open in new tab",
        "appSignInMode": false
      }
    }
  ]
}
